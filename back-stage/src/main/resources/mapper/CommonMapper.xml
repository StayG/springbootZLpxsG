<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.web.mapper.CommonMapper">


    <select id="todayAppointmentCount" resultType="java.lang.Long">
        SELECT
        COUNT(*)
        FROM
        appointment
        WHERE
        DATE ( appoint_date ) = DATE (NOW())
        <if test="merchantId != null">
            AND merchant_id = #{merchantId}
        </if>
        <if test="status != null">
            AND status = #{status}
        </if>
    </select>
</mapper>