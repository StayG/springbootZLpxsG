<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.web.mapper.ExamPaperMapper">

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        a
        .
        id
        as id
        ,a.exam_paper_name
        ,a.exam_paper_myscore
        ,a.kemu_types
        ,a.exam_paper_types
        ,a.zujuan_types
        ,a.create_time
    </sql>
    <select id="selectRespList" resultType="com.web.domain.Resp.ExamPaperResp">
        SELECT
        <include refid="Base_Column_List"/>
        <!-- 级联表的字段 -->

        FROM exam_paper a

        <where>
            <if test="req.id != null">
                and a.id in
                <foreach item="item" index="index" collection="req.id" open="(" separator="," close=")">
                    #{item}
                </foreach>
            </if>

            <if test=" req.examPaperName != '' and req.examPaperName != null and req.examPaperName != 'null' ">
                and a.exam_paper_name like CONCAT('%',#{req.examPaperName},'%')
            </if>

            <if test="req.examPaperMyscore != null and req.examPaperMyscore != ''">
                and a.exam_paper_myscore = #{req.examPaperMyscore}
            </if>

            <if test="req.kemuTypes != null">
                and a.kemu_types = #{req.kemuTypes}
            </if>
            <if test="req.examPaperTypes != null and req.examPaperTypes != ''">
                and a.exam_paper_types = #{req.examPaperTypes}
            </if>
            <if test="req.zujuanTypes != null and req.zujuanTypes != ''">
                and a.zujuan_types = #{req.zujuanTypes}
            </if>

            <!-- 数据隔离：教师只能查看自己科目的试卷 -->
            <if test="req.role != null and req.role == '教师'">
                and a.kemu_types = #{req.kemuTypes}
            </if>

        </where>
        ORDER BY a.id DESC

    </select>
</mapper>
